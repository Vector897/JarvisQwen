# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node
node_modules/
.next/
out/
*.tsbuildinfo

# Data & secrets (never commit)
data/
*.db
*.sqlite*
.env
admin_password.txt

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Docs & media stay out of the repo — README is the only committed doc
*.md
*.txt
*.jpg
*.jpeg
*.svg
*.png
*.pdf
*.docx
!README.md
!README.zh.md
# App assets are the exception — the web UI needs them
!web/public/*.png
!web/public/*.svg
!web/public/*.jpg
