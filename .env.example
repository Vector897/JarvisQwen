# ===== AAOS 环境变量（部署级配置；业务级配置在 Web 设置页热调）=====

# 数据目录（SQLite、PDF、检查点都在这里；迁移 VM 时拷走它即可）
AAOS_DATA_DIR=./data

# 会话与加密密钥（首次启动若未设置会自动生成并写入 data/secret.key）
# AAOS_SECRET_KEY=change-me-to-a-long-random-string

# 监听地址
AAOS_HOST=0.0.0.0
AAOS_PORT=8000

# 每日预算硬上限（美元，Web 设置页可改，此处是初始默认值）
AAOS_DAILY_BUDGET_USD=2.0

# 前端地址（模式 B：Vercel 域名，用于 CORS 兜底；模式 A 同源无需设置）
# AAOS_WEB_ORIGIN=https://aaos.vercel.app
