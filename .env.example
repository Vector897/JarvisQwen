DASHSCOPE_API_KEY=your_dashscope_api_key_here
# ECS_IP=your_ecs_ip_here

# 入站限流（公网部署防扫描/请求洪水）。默认开启、每分钟 240 次，正常使用达不到。
# 注意：Next 反代未透传真实客户端 IP，故为全实例级总量限流（防洪水），非严格按 IP。
# AAOS_RATELIMIT_ENABLED=true
# AAOS_RATELIMIT_RPM=240

# 访问码（公网演示强烈建议设置）：设置后 /api 必须带此码，陌生扫描器无法用你的 Key 建任务烧额度。
# 评委/你自己打开 http://<host>:3000/?k=<访问码> 一次即写 cookie，之后零摩擦。留空=完全开放。
# AAOS_ACCESS_CODE=change-me-to-a-long-random-string
